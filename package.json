{
  "name": "vai-receptionist",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "build:web": "pnpm --filter web build",
    "db:generate": "pnpm --filter web exec prisma generate",
    "db:push": "pnpm --filter web exec prisma db push",
    "db:migrate": "pnpm --filter web exec prisma migrate deploy",
    "type-check": "pnpm --filter web exec tsc --noEmit"
  }
}
