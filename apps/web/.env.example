# Database — Neon
# Pooled/serverless URL (used at runtime by Prisma + Neon HTTP driver)
DATABASE_URL=
# Direct (unpooled) URL (used by Prisma for migrations — get from Neon dashboard)
DATABASE_URL_UNPOOLED=

# Auth — Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Payments — Stripe (use test keys locally)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Email — Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Calendar — Cal.com (shared org account)
CALCOM_API_KEY=
CALCOM_EVENT_TYPE_ID=

# App URLs (set per environment)
NEXT_PUBLIC_APP_URL=
VOICE_AGENT_PUBLIC_URL=
